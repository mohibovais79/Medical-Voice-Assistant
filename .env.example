# ===== Server =====
PORT=8000
ENVIRONMENT=development  # development | production

# ===== Database (Supabase Postgres — direct connection) =====
# Get this from: Supabase Dashboard > Project Settings > Database >
#   Connection string > Transaction pooler > URI
# It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_CONN=postgresql://postgres.REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ===== Groq (LLM) =====
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Vapi =====
# Get from: https://dashboard.vapi.ai > Settings
VAPI_API_KEY=your_vapi_api_key
VAPI_PUBLIC_KEY=your_vapi_public_key  # for verifying webhook signatures
VAPI_ASSISTANT_ID=your_vapi_assistant_id  # created via CLI or dashboard
VAPI_SERVER_URL=https://your-render-app.onrender.com  # public URL Vapi will call

# ===== Optional: ngrok for local dev =====
NGROK_URL=http://localhost:8000
